<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.Inicio">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clheader"
        android:layout_width="413dp"
        android:layout_height="160dp"
        android:background="@drawable/sh_bg_header_police_blue"
        android:padding="18dp">

        <TextView
            android:id="@+id/tini1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cavosh"
            android:textColor="@color/carmine_pink"
            android:textSize="20dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tini2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="1dp"
            android:text="buenos dias usuario"
            android:textColor="@color/white"
            android:textSize="25dp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tini1" />

        <TextView
            android:id="@+id/tini3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:text="tu cafe: covosh cafe"
            android:textColor="@color/white"
            android:textSize="17dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tini2" />
        <TextView
            android:id="@+id/campana"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/ic_campana"
            android:translationZ="1dp"
            android:layout_marginTop="35dp"
            />

        <TextView
            android:id="@+id/tini4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="leginicka 20, wraclow"
            android:textColor="@color/white"
            android:textSize="15dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tini3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="change"
            android:textColor="@color/white"
            android:textSize="15dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/campana" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <SearchView
        android:id="@+id/svBuscar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="-20dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/clheader"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@drawable/sh_bg_btn_bright_gray"
        android:searchIcon="none"
         />
    <ImageView
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_buscar"
        android:padding="8dp"
        android:background="@drawable/sh_bg_btn_carmine_pink"
        app:layout_constraintTop_toTopOf="@id/svBuscar"
        app:layout_constraintEnd_toEndOf="@id/svBuscar"
        />

    <TextView
        android:id="@+id/text2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:text="nuevo pedidos"
        android:textSize="20dp"
        android:textColor="@color/police_blue"
        app:layout_constraintTop_toBottomOf="@+id/svBuscar"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@+id/text2"
        app:layout_constraintStart_toStartOf="parent"
        />

    <TextView
        android:id="@+id/text3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:textSize="20dp"
        android:text="ordenes favoritas"
        android:textColor="@color/police_blue"
        app:layout_constraintTop_toBottomOf="@+id/list1"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@+id/text3"
        app:layout_constraintStart_toStartOf="parent"
        />



   </androidx.constraintlayout.widget.ConstraintLayout>
